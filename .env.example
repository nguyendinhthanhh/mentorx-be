# MentorX Backend Environment Variables
# Copy this file to .env and update the values

# Database Configuration
DB_URL=jdbc:postgresql://localhost:5432/mentorx_db
DB_USERNAME=mentorx_user
DB_PASSWORD=mentorx_pass

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ACCESS_TOKEN_EXPIRY=900000
JWT_REFRESH_TOKEN_EXPIRY=604800000

# Wallet Configuration
WALLET_SECRET_KEY=your-wallet-secret-key-for-hash-generation

# OAuth2 Configuration
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# File Upload Configuration
FILE_UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10MB

# Application Configuration
SPRING_PROFILES_ACTIVE=dev

# Docker Configuration (for docker-compose)
DOCKER_USERNAME=your-docker-username
DOCKER_PASSWORD=your-docker-password

# Monitoring and Logging
LOG_LEVEL=INFO
ENABLE_ACTUATOR=true

# External Services
PAYMENT_GATEWAY_API_KEY=your-payment-gateway-api-key
NOTIFICATION_SERVICE_URL=http://localhost:8081

# Security
ENABLE_CSRF=false
ENABLE_CORS=true
SESSION_TIMEOUT=1800

# Performance
HIKARI_MAX_POOL_SIZE=20
HIKARI_MIN_IDLE=5

# Feature Flags
ENABLE_2FA=true
ENABLE_EMAIL_VERIFICATION=true
ENABLE_MENTOR_APPROVAL=true