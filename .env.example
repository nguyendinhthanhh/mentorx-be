# MentorX Backend Environment Variables
# Copy this file to .env and update the values
# NEVER commit .env file to git!

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
POSTGRES_DB=mentorx_db
POSTGRES_USER=mentorx_user
POSTGRES_PASSWORD=
POSTGRES_PORT=5432

# Database URL for application
DB_URL=jdbc:postgresql://localhost:5432/mentorx_db
DB_USERNAME=${POSTGRES_USER}
DB_PASSWORD=${POSTGRES_PASSWORD}

# ===========================================
# REDIS CONFIGURATION
# ===========================================
REDIS_HOST=localhost
REDIS_PORT=6379

# ===========================================
# JWT CONFIGURATION (CRITICAL - MUST CHANGE!)
# ===========================================
JWT_SECRET=
JWT_ACCESS_TOKEN_EXPIRY=900000
JWT_REFRESH_TOKEN_EXPIRY=604800000

# ===========================================
# WALLET CONFIGURATION (CRITICAL - MUST CHANGE!)
# ===========================================
WALLET_SECRET_KEY=

# ===========================================
# OAUTH2 CONFIGURATION
# ===========================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ===========================================
# EMAIL CONFIGURATION
# ===========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# ===========================================
# CORS CONFIGURATION
# ===========================================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ===========================================
# FILE UPLOAD CONFIGURATION
# ===========================================
FILE_UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10MB

# ===========================================
# APPLICATION CONFIGURATION
# ===========================================
SPRING_PROFILES_ACTIVE=dev
APP_PORT=8080

# ===========================================
# PGADMIN CONFIGURATION (for development)
# ===========================================
PGADMIN_EMAIL=admin@mentorx.local
PGADMIN_PASSWORD=
PGADMIN_PORT=5050

# ===========================================
# DOCKER CONFIGURATION
# ===========================================
DOCKER_USERNAME=
DOCKER_PASSWORD=

# ===========================================
# MONITORING AND LOGGING
# ===========================================
LOG_LEVEL=INFO
ENABLE_ACTUATOR=true

# ===========================================
# EXTERNAL SERVICES (Add when needed)
# ===========================================
# PAYMENT_GATEWAY_API_KEY=
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=
# STRIPE_SECRET_KEY=
# STRIPE_PUBLISHABLE_KEY=

# ===========================================
# SECURITY CONFIGURATION
# ===========================================
ENABLE_CSRF=false
ENABLE_CORS=true
SESSION_TIMEOUT=1800

# ===========================================
# PERFORMANCE CONFIGURATION
# ===========================================
HIKARI_MAX_POOL_SIZE=20
HIKARI_MIN_IDLE=5

# ===========================================
# FEATURE FLAGS
# ===========================================
ENABLE_2FA=true
ENABLE_EMAIL_VERIFICATION=true
ENABLE_MENTOR_APPROVAL=true